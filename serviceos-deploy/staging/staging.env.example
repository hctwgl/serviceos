# 仅用于本地/CI staging rehearsal。真实环境由 Secret Manager 注入，不复制这些占位值。
SERVICEOS_IMAGE=serviceos-backend:m17-local
SERVICEOS_ALLOW_MUTABLE_IMAGE=true
SERVICEOS_STAGING_PORT=18080
SERVICEOS_EXPECTED_MIGRATION_VERSION=029
SERVICEOS_EXPECTED_MIGRATION_COUNT=31
SERVICEOS_BOOTSTRAP_DB_PASSWORD=CHANGE_ME_BOOTSTRAP
SERVICEOS_MIGRATOR_DB_PASSWORD=CHANGE_ME_MIGRATOR
SERVICEOS_RUNTIME_DB_PASSWORD=CHANGE_ME_RUNTIME
SERVICEOS_FILE_SIGNING_KEY=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_BYTES
