{
  "realm": "serviceos",
  "enabled": true,
  "displayName": "ServiceOS Local Development",
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "project.create", "description": "Create ServiceOS operation projects" },
      { "name": "file.upload", "description": "Create and finalize private file uploads" },
      { "name": "file.download", "description": "Create short-lived private file download grants" },
      { "name": "workOrder.read", "description": "Read authorized work orders" }
    ]
  },
  "clients": [
    {
      "clientId": "serviceos-local-cli",
      "name": "ServiceOS Local CLI",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:5174/*",
        "http://127.0.0.1:5174/*",
        "http://localhost:5175/*",
        "http://127.0.0.1:5175/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://localhost:5174",
        "http://127.0.0.1:5174",
        "http://localhost:5175",
        "http://127.0.0.1:5175"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "tenant-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles-as-capabilities",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "capabilities",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "serviceos-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "serviceos-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
