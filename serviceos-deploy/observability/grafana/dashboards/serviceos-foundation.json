    {
      "datasource": {"type": "prometheus", "uid": "serviceos-prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count[5m])), 1)", "legendFormat": "5xx ratio", "refId": "A"}],
      "title": "HTTP 5xx ratio",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "serviceos-prometheus"},
