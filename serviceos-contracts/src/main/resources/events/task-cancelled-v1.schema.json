{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/task-cancelled-v1.schema.json",
  "title": "TaskCancelledV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "task.cancelled"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string"},
    "aggregateType": {"const": "Task"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 2},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {"$ref": "#/$defs/payload"}
  },
  "$defs": {
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskId", "taskType", "businessKey", "reasonCode", "sourceEventId", "cancelledAt"],
      "properties": {
        "taskId": {"type": "string", "format": "uuid"},
        "taskType": {"type": "string"},
        "businessKey": {"type": "string"},
        "reasonCode": {"const": "SERVICE_ASSIGNMENT_ACTIVATION_RECOVERED"},
        "sourceEventId": {"type": "string", "format": "uuid"},
        "cancelledAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
