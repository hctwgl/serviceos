{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/task-claimed-v1.schema.json",
  "title": "TaskClaimedV1", "type": "object", "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"}, "eventType": {"const": "task.claimed"}, "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"}, "correlationId": {"type": "string"}, "causationId": {"type": "string"},
    "aggregateType": {"const": "Task"}, "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 2}, "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {"type": "object", "additionalProperties": false,
      "required": ["taskId", "actorId", "claimedAt"],
      "properties": {
        "taskId": {"type": "string", "format": "uuid"}, "actorId": {"type": "string", "minLength": 1},
        "claimedAt": {"type": "string", "format": "date-time"}
      }}
  }
}
