{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/operational-exception-resolved-v2.schema.json",
  "title": "OperationalExceptionResolvedV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "operational.exception.resolved"},
    "schemaVersion": {"const": 2},
    "tenantId": {"type": "string", "minLength": 1},
    "correlationId": {"type": "string", "minLength": 1},
    "causationId": {"type": "string", "format": "uuid"},
    "aggregateType": {"const": "OperationalException"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exceptionId", "sourceTaskId", "sourceTaskType", "recoveryType", "recoveryRef", "handlingTaskId", "handlingTaskStatus", "resolutionCode", "resolutionActionRef", "resolutionEventId", "resolvedAt"],
      "properties": {
        "exceptionId": {"type": "string", "format": "uuid"},
        "sourceTaskId": {"type": "string", "format": "uuid"},
        "sourceTaskType": {"const": "integration.byd.submit-review"},
        "recoveryType": {"const": "OUTBOUND_DELIVERY_ACKNOWLEDGED"},
        "recoveryRef": {"type": "string", "format": "uuid"},
        "handlingTaskId": {"type": ["string", "null"], "format": "uuid"},
        "handlingTaskStatus": {"enum": ["CANCELLED", "COMPLETED", "NOT_CREATED"]},
        "resolutionCode": {"const": "OUTBOUND_DELIVERY_RECOVERED"},
        "resolutionActionRef": {"type": "string", "minLength": 1},
        "resolutionEventId": {"type": "string", "format": "uuid"},
        "resolvedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
