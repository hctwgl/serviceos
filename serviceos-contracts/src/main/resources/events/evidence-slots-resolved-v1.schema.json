{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/evidence-slots-resolved-v1.schema.json",
  "title": "EvidenceSlotsResolvedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId",
    "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"
  ],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "evidence.slots-resolved"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string", "format": "uuid"},
    "aggregateType": {"const": "EvidenceTaskResolution"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"const": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolutionId", "taskId", "projectId", "configurationBundleId",
        "configurationBundleDigest", "stageCode", "slotCount", "resolvedAt"
      ],
      "properties": {
        "resolutionId": {"type": "string", "format": "uuid"},
        "taskId": {"type": "string", "format": "uuid"},
        "projectId": {"type": "string", "format": "uuid"},
        "configurationBundleId": {"type": "string", "format": "uuid"},
        "configurationBundleDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "stageCode": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
        "slotCount": {"type": "integer", "minimum": 0},
        "resolvedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
