{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/integration-outbound-delivery-replay-requested-v1.schema.json",
  "title": "IntegrationOutboundDeliveryReplayRequestedV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "integration.outbound-delivery-replay-requested"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string"},
    "aggregateType": {"const": "OutboundDelivery"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["replayRequestId", "deliveryId", "projectId", "executionTaskId", "payloadDigest", "externalIdempotencyKey", "reason", "approvalRef", "requestedBy", "requestedAt"],
      "properties": {
        "replayRequestId": {"type": "string", "format": "uuid"},
        "deliveryId": {"type": "string", "format": "uuid"},
        "projectId": {"type": "string", "format": "uuid"},
        "executionTaskId": {"type": "string", "format": "uuid"},
        "payloadDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "externalIdempotencyKey": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 1000},
        "approvalRef": {"type": "string", "minLength": 1, "maxLength": 160},
        "requestedBy": {"type": "string", "minLength": 1, "maxLength": 160},
        "requestedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
