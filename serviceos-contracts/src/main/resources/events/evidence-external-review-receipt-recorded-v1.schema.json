{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/evidence-external-review-receipt-recorded-v1.schema.json",
  "title": "EvidenceExternalReviewReceiptRecordedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId",
    "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"
  ],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "evidence.external-review-receipt-recorded"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string"},
    "aggregateType": {"const": "ExternalReviewReceipt"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receiptId", "reviewCaseId", "reviewDecisionId", "projectId",
        "inboundEnvelopeId", "canonicalMessageId", "externalKey", "result",
        "receivedBy", "receivedAt"
      ],
      "properties": {
        "receiptId": {"type": "string", "format": "uuid"},
        "reviewCaseId": {"type": "string", "format": "uuid"},
        "reviewDecisionId": {"type": "string", "format": "uuid"},
        "projectId": {"type": "string", "format": "uuid"},
        "inboundEnvelopeId": {"type": "string", "minLength": 1, "maxLength": 160},
        "canonicalMessageId": {"type": "string", "minLength": 1, "maxLength": 160},
        "externalKey": {"type": "string", "minLength": 1, "maxLength": 160},
        "result": {"enum": ["APPROVED", "REJECTED"]},
        "coordinationTaskId": {"type": ["string", "null"], "format": "uuid"},
        "receivedBy": {"type": "string", "minLength": 1, "maxLength": 128},
        "receivedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
