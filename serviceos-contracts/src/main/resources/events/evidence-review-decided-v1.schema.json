{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/evidence-review-decided-v1.schema.json",
  "title": "EvidenceReviewDecidedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId",
    "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"
  ],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "evidence.review-decided"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string"},
    "aggregateType": {"const": "ReviewCase"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewCaseId", "reviewDecisionId", "evidenceSetSnapshotId", "taskId", "projectId",
        "decision", "reasonCodes", "decidedBy", "decidedAt"
      ],
      "properties": {
        "reviewCaseId": {"type": "string", "format": "uuid"},
        "reviewDecisionId": {"type": "string", "format": "uuid"},
        "evidenceSetSnapshotId": {"type": "string", "format": "uuid"},
        "taskId": {"type": "string", "format": "uuid"},
        "projectId": {"type": "string", "format": "uuid"},
        "decision": {"enum": ["APPROVED", "REJECTED"]},
        "reasonCodes": {
          "type": "array",
          "maxItems": 20,
          "items": {"type": "string", "minLength": 1, "maxLength": 80}
        },
        "decidedBy": {"type": "string", "minLength": 1, "maxLength": 128},
        "decidedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
