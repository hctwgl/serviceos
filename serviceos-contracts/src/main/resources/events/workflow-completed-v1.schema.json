{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/workflow-completed-v1.schema.json",
  "title": "WorkflowCompletedV1", "type": "object", "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"}, "eventType": {"const": "workflow.completed"}, "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"}, "correlationId": {"type": "string"}, "causationId": {"type": "string"},
    "aggregateType": {"const": "Workflow"}, "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 2}, "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {"type": "object", "additionalProperties": false,
      "required": ["workflowInstanceId", "projectId", "workOrderId", "workflowDefinitionVersionId", "workflowDefinitionDigest", "completedAt"],
      "properties": {
        "workflowInstanceId": {"type": "string", "format": "uuid"}, "projectId": {"type": "string", "format": "uuid"},
        "workOrderId": {"type": "string", "format": "uuid"}, "workflowDefinitionVersionId": {"type": "string", "format": "uuid"},
        "workflowDefinitionDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "completedAt": {"type": "string", "format": "date-time"}
      }}
  }
}
