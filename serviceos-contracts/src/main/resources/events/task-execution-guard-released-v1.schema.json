{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/task-execution-guard-released-v1.schema.json",
  "title": "TaskExecutionGuardReleasedV1", "type": "object", "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"}, "eventType": {"const": "task.execution-guard.released"}, "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"}, "correlationId": {"type": "string"}, "causationId": {"type": "string"},
    "aggregateType": {"const": "Task"}, "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 3}, "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {"type": "object", "additionalProperties": false,
      "required": ["taskId", "guardId", "guardType", "guardKey", "status", "reasonCode", "occurredAt"],
      "properties": {
        "taskId": {"type": "string", "format": "uuid"},
        "guardId": {"type": "string", "format": "uuid"},
        "guardType": {"const": "REASSIGNMENT"},
        "guardKey": {"type": "string", "minLength": 1, "maxLength": 160},
        "status": {"const": "RELEASED"},
        "reasonCode": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,99}$"},
        "occurredAt": {"type": "string", "format": "date-time"}
      }}
  }
}
