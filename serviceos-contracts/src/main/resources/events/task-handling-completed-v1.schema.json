{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/task-handling-completed-v1.schema.json",
  "title": "TaskHandlingCompletedV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "task.handling-completed"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string"},
    "aggregateType": {"const": "Task"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 2},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {"$ref": "#/$defs/payload"}
  },
  "$defs": {
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskId", "taskType", "businessKey", "resultRef", "resultDigest", "completedBy", "completedAt"],
      "properties": {
        "taskId": {"type": "string", "format": "uuid"},
        "taskType": {"type": "string", "minLength": 1},
        "businessKey": {"type": "string", "minLength": 1},
        "resultRef": {"type": "string", "minLength": 1},
        "resultDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "completedBy": {"type": "string", "minLength": 1},
        "completedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
