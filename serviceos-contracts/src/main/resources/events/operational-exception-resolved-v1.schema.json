{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/operational-exception-resolved-v1.schema.json",
  "title": "OperationalExceptionResolvedV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "operational.exception.resolved"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string", "format": "uuid"},
    "aggregateType": {"const": "OperationalException"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 2},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {"$ref": "#/$defs/payload"}
  },
  "$defs": {
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exceptionId", "sagaId", "serviceAssignmentId", "handlingTaskId", "handlingTaskStatus", "resolutionCode", "resolutionActionRef", "resolutionEventId", "resolvedAt"],
      "properties": {
        "exceptionId": {"type": "string", "format": "uuid"},
        "sagaId": {"type": "string", "format": "uuid"},
        "serviceAssignmentId": {"type": "string", "format": "uuid"},
        "handlingTaskId": {"type": "string", "format": "uuid"},
        "handlingTaskStatus": {"enum": ["CANCELLED", "COMPLETED"]},
        "resolutionCode": {"const": "SERVICE_ASSIGNMENT_ACTIVATION_RECOVERED"},
        "resolutionActionRef": {"type": "string"},
        "resolutionEventId": {"type": "string", "format": "uuid"},
        "resolvedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
