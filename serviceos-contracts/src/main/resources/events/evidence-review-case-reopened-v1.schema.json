{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/evidence-review-case-reopened-v1.schema.json",
  "title": "EvidenceReviewCaseReopenedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId",
    "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"
  ],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "evidence.review-case-reopened"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string"},
    "aggregateType": {"const": "ReviewCase"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceReviewCaseId", "reviewCaseId", "evidenceSetSnapshotId", "taskId", "projectId",
        "triggerRef", "reason", "reopenedBy", "reopenedAt"
      ],
      "properties": {
        "sourceReviewCaseId": {"type": "string", "format": "uuid"},
        "reviewCaseId": {"type": "string", "format": "uuid"},
        "evidenceSetSnapshotId": {"type": "string", "format": "uuid"},
        "taskId": {"type": "string", "format": "uuid"},
        "projectId": {"type": "string", "format": "uuid"},
        "triggerRef": {"type": "string", "minLength": 1, "maxLength": 160},
        "reason": {"type": "string", "minLength": 1, "maxLength": 1000},
        "reopenedBy": {"type": "string", "minLength": 1, "maxLength": 128},
        "reopenedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
