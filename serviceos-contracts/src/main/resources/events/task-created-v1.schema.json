{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/task-created-v1.schema.json",
  "title": "TaskCreatedV1", "type": "object", "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"}, "eventType": {"const": "task.created"}, "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"}, "correlationId": {"type": "string"}, "causationId": {"type": "string"},
    "aggregateType": {"const": "Task"}, "aggregateId": {"type": "string", "format": "uuid"}, "aggregateVersion": {"const": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {"type": "object", "additionalProperties": false,
      "required": ["taskId", "projectId", "workOrderId", "workflowInstanceId", "stageInstanceId", "workflowNodeInstanceId", "workflowNodeId", "taskType", "taskKind", "status", "workflowDefinitionVersionId", "workflowDefinitionDigest", "createdAt"],
      "properties": {
        "taskId": {"type": "string", "format": "uuid"}, "projectId": {"type": "string", "format": "uuid"},
        "workOrderId": {"type": "string", "format": "uuid"}, "workflowInstanceId": {"type": "string", "format": "uuid"},
        "stageInstanceId": {"type": "string", "format": "uuid"}, "workflowNodeInstanceId": {"type": "string", "format": "uuid"},
        "workflowNodeId": {"type": "string"}, "taskType": {"type": "string"},
        "taskKind": {"enum": ["AUTOMATED", "HUMAN"]}, "status": {"enum": ["PENDING", "READY"]},
        "workflowDefinitionVersionId": {"type": "string", "format": "uuid"},
        "workflowDefinitionDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "createdAt": {"type": "string", "format": "date-time"}
      }}
  }
}
