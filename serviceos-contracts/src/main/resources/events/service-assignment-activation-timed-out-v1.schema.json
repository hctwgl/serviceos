{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/service-assignment-activation-timed-out-v1.schema.json",
  "title": "ServiceAssignmentActivationTimedOutV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "service.assignment.activation-timed-out"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "correlationId": {"type": "string", "minLength": 1},
    "causationId": {"type": "string", "minLength": 1},
    "aggregateType": {"const": "ServiceAssignmentActivationSaga"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {"$ref": "#/$defs/payload"}
  },
  "$defs": {
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeoutId", "sagaId", "serviceAssignmentId", "workOrderId", "taskId", "stage", "sagaVersion", "deadlineAt", "detectedAt", "errorCode"],
      "properties": {
        "timeoutId": {"type": "string", "format": "uuid"},
        "sagaId": {"type": "string", "format": "uuid"},
        "serviceAssignmentId": {"type": "string", "format": "uuid"},
        "workOrderId": {"type": "string", "format": "uuid"},
        "taskId": {"type": "string", "format": "uuid"},
        "stage": {"enum": ["PENDING", "TASK_PREPARED", "SERVICE_SWITCHED", "TASK_ACTIVATED", "ABORTING"]},
        "sagaVersion": {"type": "integer", "minimum": 1},
        "deadlineAt": {"type": "string", "format": "date-time"},
        "detectedAt": {"type": "string", "format": "date-time"},
        "errorCode": {"const": "ACTIVATION_SAGA_TIMEOUT"}
      }
    }
  }
}
