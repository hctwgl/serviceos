{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/task-assigned-v1.schema.json",
  "title": "TaskAssignedV1", "type": "object", "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId", "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"}, "eventType": {"const": "task.assigned"}, "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"}, "correlationId": {"type": "string"}, "causationId": {"type": "string"},
    "aggregateType": {"const": "Task"}, "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 2}, "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {"type": "object", "additionalProperties": false,
      "required": ["taskId", "assignmentBatchId", "candidatePrincipalIds", "sourceType", "sourceId", "assignedAt"],
      "properties": {
        "taskId": {"type": "string", "format": "uuid"},
        "assignmentBatchId": {"type": "string", "format": "uuid"},
        "candidatePrincipalIds": {"type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 128}},
        "sourceType": {"enum": ["ASSIGNEE_POLICY", "MANUAL"]},
        "sourceId": {"type": "string", "minLength": 1, "maxLength": 160},
        "assignedAt": {"type": "string", "format": "date-time"}
      }}
  }
}
