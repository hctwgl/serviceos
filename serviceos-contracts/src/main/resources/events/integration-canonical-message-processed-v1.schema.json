{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/integration-canonical-message-processed-v1.schema.json",
  "title": "IntegrationCanonicalMessageProcessedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId",
    "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"
  ],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "integration.canonical-message-processed"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string", "format": "uuid"},
    "aggregateType": {"const": "CanonicalMessage"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"const": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalMessageId", "inboundEnvelopeId", "projectId", "connectorVersionId",
        "messageType", "businessKey", "payloadDigest", "mappingVersionId",
        "resultType", "resultId", "processedAt"
      ],
      "properties": {
        "canonicalMessageId": {"type": "string", "format": "uuid"},
        "inboundEnvelopeId": {"type": "string", "format": "uuid"},
        "projectId": {"type": "string", "format": "uuid"},
        "connectorVersionId": {"type": "string", "minLength": 1, "maxLength": 120},
        "messageType": {"const": "CREATE_WORK_ORDER"},
        "businessKey": {"type": "string", "minLength": 1, "maxLength": 200},
        "payloadDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "mappingVersionId": {"type": "string", "minLength": 1, "maxLength": 120},
        "resultType": {"const": "WORK_ORDER"},
        "resultId": {"type": "string", "format": "uuid"},
        "processedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
