{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/evidence-revision-created-v1.schema.json",
  "title": "EvidenceRevisionCreatedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId",
    "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"
  ],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "evidence.revision-created"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string"},
    "aggregateType": {"const": "EvidenceRevision"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceRevisionId", "evidenceItemId", "evidenceSlotId", "taskId", "projectId",
        "revisionNumber", "fileObjectId", "contentDigest", "status", "createdAt"
      ],
      "properties": {
        "evidenceRevisionId": {"type": "string", "format": "uuid"},
        "evidenceItemId": {"type": "string", "format": "uuid"},
        "evidenceSlotId": {"type": "string", "format": "uuid"},
        "taskId": {"type": "string", "format": "uuid"},
        "projectId": {"type": "string", "format": "uuid"},
        "revisionNumber": {"type": "integer", "minimum": 1},
        "fileObjectId": {"type": "string", "format": "uuid"},
        "contentDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "status": {"enum": ["STORED", "VALIDATING", "VALIDATED", "VALIDATION_FAILED", "QUARANTINED", "INVALIDATED"]},
        "createdAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
