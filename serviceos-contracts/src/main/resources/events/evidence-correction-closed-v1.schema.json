{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.example/schemas/events/evidence-correction-closed-v1.schema.json",
  "title": "EvidenceCorrectionClosedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId", "eventType", "schemaVersion", "tenantId", "correlationId", "causationId",
    "aggregateType", "aggregateId", "aggregateVersion", "occurredAt", "payload"
  ],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "evidence.correction-closed"},
    "schemaVersion": {"const": 1},
    "tenantId": {"type": "string"},
    "correlationId": {"type": "string"},
    "causationId": {"type": "string"},
    "aggregateType": {"const": "CorrectionCase"},
    "aggregateId": {"type": "string", "format": "uuid"},
    "aggregateVersion": {"type": "integer", "minimum": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correctionCaseId", "latestResubmissionSnapshotId", "taskId", "projectId",
        "closedBy", "closedAt"
      ],
      "properties": {
        "correctionCaseId": {"type": "string", "format": "uuid"},
        "latestResubmissionSnapshotId": {"type": "string", "format": "uuid"},
        "taskId": {"type": "string", "format": "uuid"},
        "projectId": {"type": "string", "format": "uuid"},
        "closedBy": {"type": "string"},
        "note": {"type": ["string", "null"], "maxLength": 1000},
        "closedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
