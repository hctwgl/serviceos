{
  "name": "serviceos-admin-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/ensure-core-client.mjs",
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check:tokens": "node scripts/check-hardcoded-colors.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs tests/product-labels.test.mjs",
    "test:e2e": "playwright test",
    "test:visual": "playwright test tests/e2e/final-review-visual.spec.ts tests/e2e/admin-productization-visual.spec.ts",
    "test:a11y": "playwright test tests/e2e/admin-productization-a11y.spec.ts tests/e2e/admin-fulfillment-a11y.spec.ts",
    "test:productization": "playwright test tests/e2e/admin-productization-visual.spec.ts tests/e2e/admin-productization-a11y.spec.ts tests/e2e/admin-productization-smoke.spec.ts tests/e2e/workbench-stability.spec.ts tests/e2e/admin-fulfillment-profiles.spec.ts"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@serviceos/core-client": "file:../serviceos-contracts/target/generated-clients/typescript-fetch",
    "ant-design-vue": "^4.2.6",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "axe-core": "^4.12.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5"
  }
}
