{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.local/schemas/workflow.schema.json",
  "title": "ServiceOS Workflow Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflowKey", "semanticVersion", "startNodeId", "nodes", "transitions"],
  "properties": {
    "workflowKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$", "maxLength": 160},
    "semanticVersion": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"},
    "name": {"type": "string", "minLength": 1, "maxLength": 200},
    "startNodeId": {"type": "string", "minLength": 1, "maxLength": 100},
    "terminalNodeIds": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "maxLength": 100},
      "uniqueItems": true
    },
    "nodes": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/node"}
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/transition"}
    },
    "variables": {
      "type": "array",
      "items": {"$ref": "#/$defs/variable"},
      "default": []
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "nodeType", "name"],
      "properties": {
        "nodeId": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]*$", "maxLength": 100},
        "nodeType": {
          "enum": ["START", "END", "USER_TASK", "SERVICE_TASK", "REVIEW_TASK", "WAIT_EVENT", "TIMER", "EXCLUSIVE_GATEWAY", "PARALLEL_GATEWAY", "SUB_PROCESS", "MANUAL_INTERVENTION"]
        },
        "name": {"type": "string", "minLength": 1, "maxLength": 200},
        "taskType": {"type": ["string", "null"], "maxLength": 100},
        "stageCode": {"type": ["string", "null"], "pattern": "^[A-Z0-9][A-Z0-9_-]*$", "maxLength": 100},
        "assigneePolicyRef": {"type": ["string", "null"], "maxLength": 120},
        "formRef": {"type": ["string", "null"], "maxLength": 120},
        "evidenceRef": {"type": ["string", "null"], "maxLength": 120},
        "slaRef": {"type": ["string", "null"], "maxLength": 120},
        "integrationRef": {"type": ["string", "null"], "maxLength": 120},
        "waitEventType": {
          "type": ["string", "null"],
          "pattern": "^[a-z][a-z0-9._-]*$",
          "maxLength": 160
        },
        "correlationKeyTemplate": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 300
        },
        "durationSeconds": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 31536000
        },
        "subProcessRef": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "maxLength": 160
        },
        "multiInstance": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["cardinality"],
          "properties": {
            "cardinality": {"type": "integer", "minimum": 2, "maximum": 50}
          }
        },
        "compensation": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["taskType"],
          "properties": {
            "taskType": {"type": "string", "minLength": 1, "maxLength": 100},
            "stageCode": {
              "type": ["string", "null"],
              "pattern": "^[A-Z0-9][A-Z0-9_-]*$",
              "maxLength": 100
            }
          }
        },
        "entryActions": {"type": "array", "items": {"type": "string"}, "default": []},
        "exitActions": {"type": "array", "items": {"type": "string"}, "default": []},
        "retryPolicy": {"$ref": "#/$defs/retryPolicy"},
        "failurePolicy": {
          "enum": ["FAIL_WORKFLOW", "RETRY_THEN_MANUAL", "MANUAL_IMMEDIATELY", "IGNORE_WITH_AUDIT", null]
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transitionId", "from", "to"],
      "properties": {
        "transitionId": {"type": "string", "minLength": 1, "maxLength": 120},
        "from": {"type": "string", "minLength": 1, "maxLength": 100},
        "to": {"type": "string", "minLength": 1, "maxLength": 100},
        "condition": {"$ref": "#/$defs/expression"},
        "priority": {"type": "integer", "minimum": 0, "default": 100},
        "label": {"type": ["string", "null"], "maxLength": 200}
      }
    },
    "expression": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["language", "source"],
      "properties": {
        "language": {"type": "string", "enum": ["SERVICEOS_EXPR_V1"]},
        "source": {"type": "string", "maxLength": 2000}
      }
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "source"],
      "properties": {
        "name": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*$"},
        "type": {"enum": ["STRING", "NUMBER", "BOOLEAN", "DATE", "DATETIME", "OBJECT", "ARRAY"]},
        "source": {"enum": ["WORK_ORDER", "TASK_OUTPUT", "FACT", "CONSTANT", "INTEGRATION_RESULT"]},
        "path": {"type": ["string", "null"], "maxLength": 300}
      }
    },
    "retryPolicy": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "maxAttempts": {"type": "integer", "minimum": 1, "maximum": 20},
        "initialDelaySeconds": {"type": "integer", "minimum": 0},
        "multiplier": {"type": "number", "minimum": 1, "maximum": 10},
        "maxDelaySeconds": {"type": "integer", "minimum": 0}
      }
    }
  }
}
