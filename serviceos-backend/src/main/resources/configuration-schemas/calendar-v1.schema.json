{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.local/schemas/calendar-v1.schema.json",
  "title": "ServiceOS Business Calendar",
  "type": "object",
  "additionalProperties": false,
  "required": ["calendarKey", "version", "timeZone", "weeklyWindows"],
  "properties": {
    "calendarKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$", "maxLength": 128},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"},
    "timeZone": {"type": "string", "minLength": 1, "maxLength": 64},
    "weeklyWindows": {
      "type": "array",
      "minItems": 1,
      "maxItems": 70,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dayOfWeek", "start", "end"],
        "properties": {
          "dayOfWeek": {
            "enum": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY", "SUNDAY"]
          },
          "start": {"type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"},
          "end": {"type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"}
        }
      }
    },
    "holidays": {
      "type": "array",
      "maxItems": 3660,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
      "default": []
    },
    "extraWorkdays": {
      "type": "array",
      "maxItems": 3660,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
      "default": []
    }
  }
}
