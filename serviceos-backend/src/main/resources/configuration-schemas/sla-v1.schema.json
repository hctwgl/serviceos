{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.local/schemas/sla-v1.schema.json",
  "title": "ServiceOS Task Elapsed SLA Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyKey", "version", "subjectType", "taskTypes", "startEvent", "stopEvent", "clockMode", "targetDurationSeconds"],
  "properties": {
    "policyKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$", "maxLength": 128},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"},
    "subjectType": {"const": "TASK"},
    "taskTypes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 100}
    },
    "startEvent": {"const": "TASK_CREATED"},
    "stopEvent": {"const": "TASK_COMPLETED"},
    "clockMode": {"const": "ELAPSED"},
    "targetDurationSeconds": {"type": "integer", "minimum": 1, "maximum": 31536000}
  }
}
