{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.dev/schema/assignee-policy/v1",
  "title": "ServiceOS Assignee Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyKey", "version", "strategies", "fallback"],
  "properties": {
    "policyKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$", "maxLength": 120},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "title": {"type": "string", "maxLength": 200},
    "strategies": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/strategy"}
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "roleCode"],
      "properties": {
        "mode": {"type": "string", "enum": ["MANUAL_INTERVENTION", "ROLE_POOL"]},
        "roleCode": {"type": "string", "minLength": 1, "maxLength": 64}
      }
    }
  },
  "$defs": {
    "expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "source"],
      "properties": {
        "language": {"type": "string", "enum": ["SERVICEOS_EXPR_V1"]},
        "source": {"type": "string", "minLength": 1, "maxLength": 2000}
      }
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategyKey", "candidateType", "priority", "when"],
      "properties": {
        "strategyKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$", "maxLength": 64},
        "candidateType": {
          "type": "string",
          "enum": ["USER", "ROLE", "ORGANIZATION", "NETWORK"]
        },
        "priority": {"type": "integer", "minimum": 1, "maximum": 1000},
        "when": {"$ref": "#/$defs/expression"},
        "roleCode": {"type": "string", "maxLength": 64},
        "maxCandidates": {"type": "integer", "minimum": 1, "maximum": 100}
      }
    }
  }
}
