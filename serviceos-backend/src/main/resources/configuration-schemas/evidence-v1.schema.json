{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.dev/schema/evidence/v1",
  "title": "ServiceOS Evidence Template",
  "type": "object",
  "additionalProperties": false,
  "required": ["templateKey", "version", "items"],
  "properties": {
    "templateKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "title": {"type": "string"},
    "stage": {"type": "string", "enum": ["SURVEY", "INSTALLATION", "REPAIR", "REVIEW", "OTHER"]},
    "items": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/item"}},
    "rejectReasonLibraryRef": {"type": "string"}
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceKey", "name", "mediaType", "required"],
      "properties": {
        "evidenceKey": {"type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._-]+$"},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "mediaType": {"type": "string", "enum": ["PHOTO", "VIDEO", "DOCUMENT", "SIGNATURE", "GENERATED_REPORT"]},
        "required": {"type": "boolean"},
        "requiredWhen": {"$ref": "#/$defs/expression"},
        "capture": {"$ref": "#/$defs/capture"},
        "qualityChecks": {"type": "array", "items": {"$ref": "#/$defs/check"}, "default": []},
        "contentChecks": {"type": "array", "items": {"$ref": "#/$defs/check"}, "default": []},
        "reviewPolicy": {"$ref": "#/$defs/reviewPolicy"},
        "externalMappingRef": {"type": "string"}
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowCamera": {"type": "boolean", "default": true},
        "allowGallery": {"type": "boolean", "default": true},
        "requireRealtimeCapture": {"type": "boolean", "default": false},
        "requireGps": {"type": "boolean", "default": false},
        "maxDistanceMeters": {"type": "integer", "minimum": 0},
        "watermarkFields": {"type": "array", "items": {"type": "string", "enum": ["TIME", "GPS", "ADDRESS", "TECHNICIAN_NAME", "WORK_ORDER_NO"]}},
        "minCount": {"type": "integer", "minimum": 0, "default": 1},
        "maxCount": {"type": "integer", "minimum": 1},
        "maxSizeBytes": {"type": "integer", "minimum": 1},
        "maxDurationSeconds": {"type": "integer", "minimum": 1}
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkType", "severity"],
      "properties": {
        "checkType": {"type": "string", "enum": ["BLUR", "DARK", "GLARE", "DUPLICATE", "HISTORICAL_IMAGE", "GPS_DISTANCE", "OCR", "SN_MATCH", "VIN_MATCH", "CUSTOM_RULE"]},
        "severity": {"type": "string", "enum": ["WARN", "BLOCK"]},
        "parameters": {"type": "object"},
        "expression": {"$ref": "#/$defs/expression"}
      }
    },
    "reviewPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewRequired": {"type": "boolean", "default": true},
        "reviewerStrategyRef": {"type": "string"},
        "allowItemLevelReject": {"type": "boolean", "default": true},
        "allowMultipleCorrections": {"type": "boolean", "default": true},
        "lockAfterApproval": {"type": "boolean", "default": true},
        "allowForceApproveCapability": {"type": "string"}
      }
    },
    "expression": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["language", "source"],
      "properties": {
        "language": {"type": "string", "enum": ["SERVICEOS_EXPR_V1"]},
        "source": {"type": "string", "maxLength": 2000}
      }
    }
  }
}
