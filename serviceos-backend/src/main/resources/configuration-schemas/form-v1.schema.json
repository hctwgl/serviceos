{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.dev/schema/form/v1",
  "title": "ServiceOS Form Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["formKey", "version", "sections"],
  "properties": {
    "formKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "title": {"type": "string", "minLength": 1},
    "stage": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]*$", "maxLength": 100},
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/section"}
    },
    "validationRules": {
      "type": "array",
      "items": {"$ref": "#/$defs/rule"},
      "default": []
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sectionKey", "title", "fields"],
      "properties": {
        "sectionKey": {"type": "string"},
        "title": {"type": "string"},
        "visibility": {"$ref": "#/$defs/expression"},
        "fields": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/field"}}
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fieldKey", "label", "dataType", "binding"],
      "properties": {
        "fieldKey": {"type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._-]+$"},
        "label": {"type": "string"},
        "dataType": {"type": "string", "enum": ["STRING", "TEXT", "INTEGER", "DECIMAL", "BOOLEAN", "DATE", "DATETIME", "ENUM", "MULTI_ENUM", "ADDRESS", "GEOPOINT", "SIGNATURE", "FILE_REF", "OBJECT", "OBJECT_LIST"]},
        "binding": {"type": "string", "description": "Declared writable domain or task input path"},
        "required": {"type": "boolean", "default": false},
        "requiredWhen": {"$ref": "#/$defs/expression"},
        "visibleWhen": {"$ref": "#/$defs/expression"},
        "editableWhen": {"$ref": "#/$defs/expression"},
        "defaultExpression": {"$ref": "#/$defs/expression"},
        "optionsRef": {"type": "string"},
        "sensitiveClass": {"type": "string", "enum": ["PUBLIC", "INTERNAL", "PERSONAL", "SENSITIVE_PERSONAL", "FINANCIAL"]},
        "validators": {"type": "array", "items": {"$ref": "#/$defs/validator"}, "default": []}
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {"type": "string", "enum": ["LENGTH", "RANGE", "REGEX", "ENUM", "EXPRESSION", "UNIQUE", "REFERENCE_EXISTS"]},
        "parameters": {"type": "object"},
        "message": {"type": "string"}
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ruleKey", "assert"],
      "properties": {
        "ruleKey": {"type": "string"},
        "assert": {"$ref": "#/$defs/expression"},
        "message": {"type": "string"}
      }
    },
    "expression": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["language", "source"],
      "properties": {
        "language": {"type": "string", "enum": ["SERVICEOS_EXPR_V1"]},
        "source": {"type": "string", "maxLength": 2000}
      }
    }
  }
}
