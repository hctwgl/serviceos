{
  "policyKey": "product.byd-ocean.network-dispatch",
  "version": "1.0.0",
  "scope": {
    "brandCodes": ["BYD_OCEAN"],
    "businessTypes": ["HOME_CHARGING_SURVEY_INSTALL"],
    "regionCodes": ["370000"]
  },
  "hardFilters": [
    {
      "filterKey": "ENABLED",
      "order": 1,
      "expression": {
        "language": "SERVICEOS_EXPR_V1",
        "source": "workOrder.brandCode == \"BYD_OCEAN\""
      },
      "failureCode": "DISABLED"
    },
    {
      "filterKey": "CAPACITY",
      "order": 2,
      "expression": {
        "language": "SERVICEOS_EXPR_V1",
        "source": "workOrder.serviceProductCode == \"HOME_CHARGING_SURVEY_INSTALL\""
      },
      "failureCode": "NO_CAPACITY"
    }
  ],
  "scoring": [
    {
      "factorKey": "REMAINING_CAPACITY",
      "weight": 1.0,
      "expression": {
        "language": "SERVICEOS_EXPR_V1",
        "source": "workOrder.brandCode == \"BYD_OCEAN\""
      }
    }
  ],
  "capacity": {"reservationRequired": true},
  "fallback": {
    "onNoCandidate": "MANUAL_INTERVENTION",
    "manualRole": "OPS",
    "resolutionHours": 4
  }
}
