# 仅供本地开发代理；应用 API base 保持同源，避免把开发地址烘焙进生产制品。
VITE_SERVICEOS_API_BASE_URL=/api/v1
VITE_SERVICEOS_CLIENT_VERSION=0.1.0-dev.1
VITE_DEV_API_PROXY=http://127.0.0.1:8080
VITE_DEV_OIDC_ENABLED=true
VITE_DEV_OIDC_ISSUER=http://localhost:8081/realms/serviceos
VITE_DEV_OIDC_CLIENT_ID=serviceos-local-cli

# Staging/Production 使用 VITE_OIDC_*；非开发环境 issuer 必须为 HTTPS。
# VITE_OIDC_ENABLED=true
# VITE_OIDC_ISSUER=https://identity.example/realms/serviceos
# VITE_OIDC_CLIENT_ID=serviceos-technician-web
