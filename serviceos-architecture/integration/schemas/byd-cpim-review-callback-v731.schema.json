{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.local/schemas/byd-cpim-review-callback-v731.schema.json",
  "title": "BYD CPIM V7.3.1 Review Callback",
  "type": "object",
  "additionalProperties": false,
  "required": ["orderCode", "result", "examinePerson", "examineDate"],
  "properties": {
    "orderCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[^,]+(,[^,]+){0,99}$"
    },
    "result": {"type": "string", "enum": ["1", "2"]},
    "remark": {"type": "string", "maxLength": 200},
    "examinePerson": {"type": "string", "minLength": 1, "maxLength": 50},
    "examineDate": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"}
  },
  "allOf": [
    {
      "if": {"properties": {"result": {"const": "2"}}, "required": ["result"]},
      "then": {"required": ["remark"]}
    }
  ]
}
