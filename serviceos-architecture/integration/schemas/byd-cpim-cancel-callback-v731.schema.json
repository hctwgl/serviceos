{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.local/schemas/byd-cpim-cancel-callback-v731.schema.json",
  "title": "BYD CPIM V7.3.1 Cancel Callback",
  "type": "object",
  "additionalProperties": false,
  "required": ["orderCode", "cancelDate"],
  "properties": {
    "orderCode": {"type": "string", "minLength": 1, "maxLength": 50},
    "cancelDate": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"},
    "cancelDesc": {"type": "string", "maxLength": 200},
    "cancelReason": {"type": "string", "maxLength": 200}
  }
}
