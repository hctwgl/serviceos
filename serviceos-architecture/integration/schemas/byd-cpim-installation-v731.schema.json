{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.local/schemas/byd-cpim-installation-v731.schema.json",
  "title": "BYD CPIM V7.3.1 Installation Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["operatePerson", "orderCode", "wallboxCode", "installationCompletedTime", "cableBrand", "frontEndCable", "attachmentSource"],
  "properties": {
    "operatePerson": {"type": "string", "minLength": 1, "maxLength": 50},
    "orderCode": {"type": "string", "minLength": 1, "maxLength": 50},
    "wallboxCode": {"type": "string", "minLength": 1, "maxLength": 50},
    "installationCompletedTime": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"},
    "installationCode": {"type": "string", "maxLength": 50},
    "powerSupplyMethod": {"type": "string", "enum": ["1", "2", "3", "10"]},
    "cableBrand": {"type": "string", "enum": ["1", "2", "3", "4", "5", "10"]},
    "cableType": {"type": "string", "maxLength": 50},
    "cableLength": {"type": "integer", "minimum": 0},
    "breakerBrand": {"type": "string", "maxLength": 50},
    "breakerType": {"type": "string", "maxLength": 50},
    "installStake": {"type": "string", "enum": ["0", "1"]},
    "installProtectingBox": {"type": "string", "enum": ["0", "1"]},
    "groundElectrode": {"type": "string", "enum": ["1", "2"]},
    "frontEndCable": {"type": "string", "enum": ["1", "2", "9"]},
    "attachmentSource": {"type": "string", "enum": ["1", "2", "3"]}
  }
}
