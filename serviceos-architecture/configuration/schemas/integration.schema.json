{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.dev/schema/integration/v1",
  "title": "ServiceOS Integration Mapping",
  "type": "object",
  "additionalProperties": false,
  "required": ["mappingKey", "version", "connectorCode", "direction", "fieldMappings"],
  "properties": {
    "mappingKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$", "maxLength": 120},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "connectorCode": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{1,63}$"},
    "direction": {"type": "string", "enum": ["INBOUND", "OUTBOUND"]},
    "title": {"type": "string", "maxLength": 200},
    "fieldMappings": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/fieldMapping"}
    }
  },
  "$defs": {
    "scalar": {
      "type": ["string", "number", "boolean"]
    },
    "sourceCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourcePath", "operator"],
      "properties": {
        "sourcePath": {"type": "string", "minLength": 1, "maxLength": 200},
        "operator": {
          "type": "string",
          "enum": ["PRESENT", "EQUALS", "NOT_EQUALS", "IN", "NOT_IN"]
        },
        "value": {"$ref": "#/$defs/scalar"},
        "values": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {"$ref": "#/$defs/scalar"}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"operator": {"const": "PRESENT"}},
            "required": ["operator"]
          },
          "then": {
            "not": {
              "anyOf": [
                {"required": ["value"]},
                {"required": ["values"]}
              ]
            }
          }
        },
        {
          "if": {
            "properties": {"operator": {"enum": ["EQUALS", "NOT_EQUALS"]}},
            "required": ["operator"]
          },
          "then": {"required": ["value"]}
        },
        {
          "if": {
            "properties": {"operator": {"enum": ["IN", "NOT_IN"]}},
            "required": ["operator"]
          },
          "then": {"required": ["values"]}
        }
      ]
    },
    "fieldMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mappingId", "required"],
      "properties": {
        "mappingId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$", "maxLength": 64},
        "externalPath": {"type": "string", "minLength": 1, "maxLength": 200},
        "internalPath": {"type": "string", "minLength": 1, "maxLength": 200},
        "required": {"type": "boolean"},
        "transform": {
          "type": "string",
          "enum": ["NONE", "TRIM", "UPPER", "LOWER", "DATE_ISO"]
        },
        "constantValue": {"$ref": "#/$defs/scalar"},
        "defaultValue": {"$ref": "#/$defs/scalar"},
        "enumMap": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 64,
          "additionalProperties": {"type": "string", "minLength": 1, "maxLength": 200}
        },
        "condition": {"$ref": "#/$defs/sourceCondition"}
      },
      "allOf": [
        {
          "if": {"required": ["constantValue"]},
          "then": {
            "not": {
              "anyOf": [
                {"required": ["defaultValue"]},
                {"required": ["enumMap"]}
              ]
            }
          },
          "else": {"required": ["externalPath", "internalPath"]}
        }
      ]
    }
  }
}
