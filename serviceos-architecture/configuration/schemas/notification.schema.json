{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.dev/schema/notification/v1",
  "title": "ServiceOS Notification Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyKey", "version", "triggers", "defaultChannel"],
  "properties": {
    "policyKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$", "maxLength": 120},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "title": {"type": "string", "maxLength": 200},
    "defaultChannel": {
      "type": "string",
      "enum": ["IN_APP", "SMS", "EMAIL", "PUSH"]
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/trigger"}
    }
  },
  "$defs": {
    "expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "source"],
      "properties": {
        "language": {"type": "string", "enum": ["SERVICEOS_EXPR_V1"]},
        "source": {"type": "string", "minLength": 1, "maxLength": 2000}
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["triggerKey", "eventType", "templateKey", "channel", "when"],
      "properties": {
        "triggerKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$", "maxLength": 64},
        "eventType": {"type": "string", "minLength": 1, "maxLength": 120},
        "templateKey": {"type": "string", "minLength": 1, "maxLength": 120},
        "channel": {"type": "string", "enum": ["IN_APP", "SMS", "EMAIL", "PUSH"]},
        "when": {"$ref": "#/$defs/expression"},
        "recipientRole": {"type": "string", "maxLength": 64}
      }
    }
  }
}
