{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serviceos.dev/schema/pricing/v1",
  "title": "ServiceOS Pricing Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["pricingKey", "version", "currency", "lines"],
  "properties": {
    "pricingKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$", "maxLength": 120},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "title": {"type": "string", "maxLength": 200},
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/pricingLine"}
    }
  },
  "$defs": {
    "expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "source"],
      "properties": {
        "language": {"type": "string", "enum": ["SERVICEOS_EXPR_V1"]},
        "source": {"type": "string", "minLength": 1, "maxLength": 2000}
      }
    },
    "pricingLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lineKey", "chargeCode", "amountMinor", "when"],
      "properties": {
        "lineKey": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$", "maxLength": 64},
        "chargeCode": {"type": "string", "minLength": 1, "maxLength": 64},
        "amountMinor": {"type": "integer", "minimum": 0},
        "when": {"$ref": "#/$defs/expression"},
        "billableTo": {"type": "string", "enum": ["OEM", "NETWORK", "PLATFORM", "CUSTOMER"]}
      }
    }
  }
}
